<odoo>
    <record id="view_res_users_form_api_token" model="ir.ui.view">
        <field name="name">res.users.form.api.token</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='action_id']" position="after">
                <group string="API Token" colspan="2">
                    <field name="api_token" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
