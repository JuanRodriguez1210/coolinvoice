<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_dian_document">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="o">

                <t t-call="web.external_layout">

                    <div class="page">

                        <!-- HEADER -->
                        <div class="row mb-4">

                            <div class="col-6">

                                <img t-if="o.company_id.logo"
                                     t-att-src="image_data_uri(o.company_id.logo)"
                                     style="max-height:90px;"/>

                            </div>

                            <div class="col-6 text-end">

                                <h2>
                                    FACTURA ELECTRÓNICA
                                </h2>

                                <strong>
                                    <span t-out="o.name"/>
                                </strong>

                                <br/>

                                <span t-out="o.company_id.name"/>

                                <br/>

                                <strong>NIT:</strong>
                                <span t-out="o.company_id.partner_id.vat or ''"/>

                            </div>

                        </div>

                        <!-- CLIENTE -->
                        <div class="mb-3">

                            <strong>Cliente:</strong>
                            <span t-out="o.partner_id.name or ''"/>

                            <br/>

                            <strong>NIT / CC:</strong>
                            <span t-out="o.partner_id.vat or ''"/>

                        </div>

                        <!-- LINEAS -->
                        <table class="table table-sm table-bordered">

                            <thead>

                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">Precio</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>

                            </thead>

                            <tbody>

                                <tr t-foreach="o.invoice_line_ids"
                                    t-as="line">

                                    <td>
                                        <span t-out="line.name or ''"/>
                                    </td>

                                    <td class="text-center">
                                        <span t-out="line.quantity"/>
                                    </td>

                                    <td class="text-end">
                                        <span t-out="line.price_unit"/>
                                    </td>

                                    <td class="text-end">
                                        <span t-out="line.price_subtotal"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                        <!-- TOTALES -->
                        <div class="row mt-4">

                            <div class="col-6">

                                <!-- RESOLUCION DIAN -->
                                <strong>
                                    Resolución DIAN
                                </strong>

                                <br/>

                                <!-- NUMERO RESOLUCION -->
                                <t t-if="'l10n_co_dian_resolution_number' in o.journal_id._fields">

                                    <span t-out="o.journal_id.l10n_co_dian_resolution_number or ''"/>

                                </t>

                                <br/>

                                <!-- FECHA RESOLUCION -->
                                <strong>Vigencia:</strong>

                                <t t-if="'l10n_co_dian_resolution_date' in o.journal_id._fields">

                                    <span t-out="o.journal_id.l10n_co_dian_resolution_date or ''"/>

                                </t>

                            </div>

                            <div class="col-6 text-end">

                                <div>
                                    Subtotal:
                                    <strong t-out="o.amount_untaxed"/>
                                </div>

                                <div>
                                    IVA:
                                    <strong t-out="o.amount_tax"/>
                                </div>

                                <div style="font-size:18px;">

                                    TOTAL:
                                    <strong t-out="o.amount_total"/>

                                </div>

                            </div>

                        </div>

                        <!-- CUFE -->
                        <div class="mt-4"
                             t-if="'l10n_co_edi_cufe_cude_ref' in o._fields and o.l10n_co_edi_cufe_cude_ref">

                            <strong>
                                CUFE
                            </strong>

                            <br/>

                            <span style="font-size:11px;"
                                  t-out="o.l10n_co_edi_cufe_cude_ref"/>

                        </div>

                        <!-- QR -->
                        <div class="mt-3"
                             t-if="'l10n_co_edi_qr_code' in o._fields and o.l10n_co_edi_qr_code">

                            <img t-att-src="image_data_uri(o.l10n_co_edi_qr_code)"
                                 style="width:140px;height:140px;"/>

                        </div>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>